{
  "name": "agent-skills",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Sync agent skills/rules/suggestions to Cursor and Claude Code from a unified Markdown source.",
  "main": "./dist/index.js",
  "bin": {
    "agent-skills": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "test": "jest",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "precommit": "npm run format:check && npm run lint && npm run build && npm run test",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "publish": "npm publish --access public"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "husky": "^9.0.0"
  }
}
